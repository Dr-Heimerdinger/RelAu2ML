# Lightweight Backend Dockerfile (Development)
# Uses CPU torch for faster builds — no GPU required
# Use this during development with: docker compose -f docker-compose.dev.yml build backend

FROM python:3.11-slim as base

WORKDIR /app

ENV PIP_DEFAULT_TIMEOUT=100 \
    PIP_RETRIES=5 \
    PYTHONUNBUFFERED=1 \
    UV_SYSTEM_PYTHON=1 \
    UV_NO_CACHE=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

FROM base as deps

RUN pip install --no-cache-dir uv

COPY pyproject.toml README.md ./

# Create minimal package stub so uv can resolve dependencies before source is copied
# (enables Docker layer caching — this layer is reused unless pyproject.toml changes)
RUN mkdir -p plexe && touch plexe/__init__.py

# Install main deps + chatui
RUN uv pip install ".[chatui]"

# Force CPU torch (replaces default CUDA-capable torch with a smaller CPU wheel)
RUN uv pip install torch==2.3.1 --index-url https://download.pytorch.org/whl/cpu

# PyG C-extensions — only available from the PyG wheel index, not standard PyPI
RUN pip install pyg_lib torch_scatter torch_sparse torch_cluster torch_spline_conv \
    -f https://data.pyg.org/whl/torch-2.3.1+cpu.html

FROM deps as app

COPY . .

# Re-install in editable mode
RUN uv pip install -e ".[chatui]"

# Re-pin CPU torch + PyG extensions (guard against uv pulling a newer torch)
RUN uv pip install torch==2.3.1 --index-url https://download.pytorch.org/whl/cpu && \
    pip install pyg_lib torch_scatter torch_sparse torch_cluster torch_spline_conv \
    -f https://data.pyg.org/whl/torch-2.3.1+cpu.html

# sentence-transformers for text embeddings in GNN training
RUN uv pip install sentence-transformers

EXPOSE 8000

HEALTHCHECK --interval=10s --timeout=5s --retries=3 --start-period=30s \
  CMD python -c "import requests; requests.get('http://localhost:8000/health', timeout=2)"

CMD ["sh", "-c", "python -m uvicorn plexe.server:app --host 0.0.0.0 --port ${BACKEND_PORT:-8000} --reload --reload-dir plexe"]