FROM pytorch/pytorch:2.10.0-cuda12.8-cudnn9-runtime
ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /app
 
# ----------------------------
# System dependencies
# ----------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-dev \
    python3-venv \
    python3-pip \
    git \
    curl \
    build-essential \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Avoid PEP 668 "externally-managed-environment" by using a venv.
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
 
# ----------------------------
# Install uv (fast Python package manager)
# ----------------------------
RUN python -m pip install --no-cache-dir uv
 
# ----------------------------
# Environment variables
# ----------------------------
ENV PYTHONUNBUFFERED=1 \
    PIP_DEFAULT_TIMEOUT=100 \
    PIP_RETRIES=5 \
    UV_NO_CACHE=1
 
# ----------------------------
# BƯỚC 1: Copy dependency files
# ----------------------------
COPY pyproject.toml README.md ./
 
# ----------------------------
# BƯỚC 2: Install main + extras từ pyproject.toml
# torch 2.10.0+cu128 trong base image thỏa mãn >=2.3.0,<3 — uv giữ nguyên
# Tạo stub trước để Docker layer cache hoạt động khi chỉ pyproject.toml thay đổi
# ----------------------------
RUN mkdir -p plexe && touch plexe/__init__.py
#
# IMPORTANT: Keep CUDA runtime compatible with host driver (CUDA 12.8 here).
# Without pinning, installing torchvision/torchaudio can upgrade torch to cu130,
# which will fail on a CUDA 12.8 driver and silently force CPU.
#
RUN uv pip install --index-url https://download.pytorch.org/whl/cu128 \
    "torch==2.10.0+cu128" \
    "torchvision==0.25.0+cu128" \
    "torchaudio==2.10.0+cu128"
RUN uv pip install ".[transformers,chatui]"
 
# ----------------------------
# BƯỚC 4: PyTorch Geometric dependencies (dùng pip vì PyG wheel index)
# Theo hướng dẫn chính thức: https://pytorch-geometric.readthedocs.io
# ----------------------------
RUN uv pip install pyg_lib torch_scatter torch_sparse torch_cluster torch_spline_conv \
    -f https://data.pyg.org/whl/torch-2.10.0+cu128.html
 
# ----------------------------
# BƯỚC 5: Extra packages không có trong pyproject.toml
# ----------------------------
RUN uv pip install tensorboard
 
# ----------------------------
# Source code
# ----------------------------
COPY . .

# Re-install package in editable mode
RUN uv pip install -e ".[transformers,chatui]"
 
# ----------------------------
# Sanity check (build-time - GPU not available during build)
# ----------------------------
RUN python - <<EOF
import torch
print("Torch:", torch.__version__)
print("Note: CUDA will be available at runtime, not during build")
import torch_geometric
print("PyG OK")
import sentence_transformers
print("sentence-transformers:", sentence_transformers.__version__)
from plexe import PlexeOrchestrator
print("plexe import OK")
from plexe.langgraph import EDAAgent, ConversationalAgent
print("LangGraph agents OK")
EOF
 
CMD ["sh", "-c", "python -m uvicorn plexe.server:app --host 0.0.0.0 --port ${BACKEND_PORT:-8100} --reload --reload-dir plexe"]